# Renomeie para .env apenas se precisar sobrescrever estes valores locais.
WEB_PORT=8080
API_PORT=8010
MYSQL_PORT=3306
MYSQL_DATABASE=rag_ingest
MYSQL_USER=rag
MYSQL_PASSWORD=rag_secret
MYSQL_ROOT_PASSWORD=root_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=rag-documents
QDRANT_PORT=6335
QDRANT_GRPC_PORT=6336
QDRANT_COLLECTION=rag_chunks
SPARSE_MODEL=Qdrant/bm25
SPARSE_LANGUAGE=portuguese
# Senha temporária de acesso ao painel e à API. Troque antes de expor o serviço.
INGEST_APP_PASSWORD=morango
# Tempo de validade da sessão no navegador (8 horas).
INGEST_AUTH_TOKEN_TTL_SECONDS=28800
DOCLING_ENABLED=true
