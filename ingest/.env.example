# Renomeie para .env apenas se precisar sobrescrever estes valores locais.
WEB_PORT=8080
API_PORT=8010
MYSQL_PORT=3306
MYSQL_PASSWORD=rag_secret
MYSQL_ROOT_PASSWORD=root_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_PASSWORD=minioadmin
QDRANT_PORT=6335
QDRANT_GRPC_PORT=6336
# Senha temporária de acesso ao painel e à API. Troque antes de expor o serviço.
INGEST_APP_PASSWORD=alterar-esta-senha

# Chunking
# Opções: fixed_token, recursive_text, docling_hierarchical, docling_hybrid,
# docling_hybrid_parent_child, docling_hybrid_contextual
CHUNKING_STRATEGY=recursive_text
CHUNK_MIN_WORDS=180
CHUNK_SIZE_WORDS=700
CHUNK_OVERLAP_WORDS=100
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
PARENT_CHILD_SIZE_WORDS=320
PARENT_CHILD_OVERLAP_WORDS=60
