# Renomeie para .env apenas se precisar sobrescrever estes valores locais.
CHAT_WEB_PORT=8081
CHAT_API_PORT=8011

# Senha de acesso ao painel e à API do chat.
CHAT_APP_PASSWORD=alterar-esta-senha

# Deve ser igual ao INGEST_APP_PASSWORD configurado no módulo ingest.
INGEST_APP_PASSWORD=alterar-esta-senha

# Chave do provedor compatível com OpenAI/OpenRouter.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=deepseek/deepseek-v4-flash

# O painel RAGAS do site usa a biblioteca oficial ragas.
# Se vazio, RAGAS_MODEL usa LLM_MODEL.
RAGAS_MODEL=
RAGAS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAGAS_EMBEDDING_DEVICE=
